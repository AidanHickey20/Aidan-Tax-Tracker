generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── NextAuth models ──

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  accounts    Account[]
  sessions    Session[]

  password      String?

  weeklyEntries      WeeklyEntry[]
  recurringItems     RecurringItem[]
  trackedInvestments      TrackedInvestment[]
  investmentTransactions  InvestmentTransaction[]
  deals              Deal[]
  reminders          Reminder[]
  settings           UserSettings?
  userAccounts       UserAccount[]
  subscription       Subscription?
}

model UserSettings {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  incomeGoal          Float @default(0)
  bankBalance         Float @default(0)
  homeValue           Float @default(0)
  homeAppreciation    Float @default(0)
  mortgageBalance     Float @default(0)
  mortgageRate        Float @default(0)
  mortgagePayment     Float @default(0)
  studentLoanBalance  Float @default(0)
  studentLoanRate     Float @default(0)
  studentLoanPayment  Float @default(0)
  carLoanBalance      Float @default(0)
  carLoanRate         Float @default(0)
  carLoanPayment      Float @default(0)
  refDate             DateTime @default(now())

  studentLoanPaymentDay Int   @default(1)
  carLoanPaymentDay     Int   @default(16)
  investmentGrowthRate  Float @default(0.07)
}

model UserAccount {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String   // e.g. "Personal", "Coinbase - Bitcoin"
  category  String   // CASH, INVESTMENT, CRYPTO, RETIREMENT
  group     String?  // e.g. "Coinbase", "Robinhood", or null for standalone
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([userId, name])
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── App models ──

model WeeklyEntry {
  id        String   @id @default(uuid())
  weekStart DateTime
  weekEnd   DateTime
  mileage   Float    @default(0)
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  lineItems       LineItem[]
  accountBalances AccountBalance[]
  investments     InvestmentEntry[]
}

model LineItem {
  id            String @id @default(uuid())
  description   String
  amount        Float
  category      String // INCOME, BUSINESS_EXPENSE, PERSONAL_EXPENSE, OWNER_DRAW

  weeklyEntry   WeeklyEntry @relation(fields: [weeklyEntryId], references: [id], onDelete: Cascade)
  weeklyEntryId String
}

model AccountBalance {
  id          String @id @default(uuid())
  accountName String
  balance     Float

  weeklyEntry   WeeklyEntry @relation(fields: [weeklyEntryId], references: [id], onDelete: Cascade)
  weeklyEntryId String
}

model InvestmentEntry {
  id     String @id @default(uuid())
  name   String
  amount Float

  weeklyEntry   WeeklyEntry @relation(fields: [weeklyEntryId], references: [id], onDelete: Cascade)
  weeklyEntryId String
}

model RecurringItem {
  id           String   @id @default(uuid())
  description  String
  amount       Float
  category     String   // INCOME, BUSINESS_EXPENSE, PERSONAL_EXPENSE, OWNER_DRAW, INVESTMENT
  frequency    String   @default("WEEKLY") // WEEKLY or MONTHLY
  scheduledDay Int      @default(-1) // WEEKLY: 0=Sun..6=Sat, MONTHLY: 1-31, -1=unset
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TrackedInvestment {
  id               String   @id @default(uuid())
  symbol           String   // Ticker for stocks (AAPL), CoinGecko ID for crypto (bitcoin)
  name             String   // Display name
  type             String   // STOCK or CRYPTO
  shares           Float    @default(0)
  avgCost          Float    @default(0)
  recurringAmount   Float     @default(0) // Weekly auto-invest amount in USD
  recurringDay      Int       @default(-1) // Day of week: 0=Sun,1=Mon,...6=Sat, -1=disabled
  lastProcessedDate DateTime? // Last auto-invest execution date
  createdAt         DateTime  @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions InvestmentTransaction[]
}

model InvestmentTransaction {
  id           String            @id @default(uuid())
  investmentId String
  investment   TrackedInvestment @relation(fields: [investmentId], references: [id], onDelete: Cascade)
  type         String            // "AUTO_INVEST"
  amount       Float             // USD spent
  price        Float             // Price per share at time of purchase
  shares       Float             // Shares acquired
  executedAt   DateTime          @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Deal {
  id           String        @id @default(uuid())
  address      String
  nickname     String        @default("")
  purchasePrice Float        @default(0)
  arv          Float         @default(0) // After Repair Value
  status       String        @default("ACQUISITION") // current phase
  notes        String        @default("")
  closedAt     DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  expenses     DealExpense[]
  steps        DealStep[]
}

model DealExpense {
  id          String   @id @default(uuid())
  description String
  amount      Float
  category    String   // ACQUISITION, DEMO, MATERIALS, LABOR, PERMITS, UTILITIES, INSURANCE, CLOSING, OTHER
  paidAt      DateTime @default(now())

  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId      String
}

model DealStep {
  id          String    @id @default(uuid())
  name        String    // ACQUISITION, DEMO, RENOVATION, LISTING, UNDER_CONTRACT, CLOSED
  completed   Boolean   @default(false)
  completedAt DateTime?
  notes       String    @default("")
  sortOrder   Int       @default(0)

  deal        Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId      String
}

model Reminder {
  id           String   @id @default(uuid())
  message      String
  frequency    String   @default("WEEKLY") // WEEKLY or MONTHLY
  scheduledDay Int      @default(-1) // WEEKLY: 0=Sun..6=Sat, MONTHLY: 1-31, -1=unset
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                   String    @id @default(uuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  plan                 String    @default("TRIAL")  // TRIAL, BASIC, PRO
  status               String    @default("ACTIVE") // ACTIVE, PAST_DUE, CANCELED, EXPIRED
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}
