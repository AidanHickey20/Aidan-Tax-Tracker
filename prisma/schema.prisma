generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model WeeklyEntry {
  id        String   @id @default(uuid())
  weekStart DateTime
  weekEnd   DateTime
  mileage   Float    @default(0)
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lineItems       LineItem[]
  accountBalances AccountBalance[]
  investments     InvestmentEntry[]
}

model LineItem {
  id            String @id @default(uuid())
  description   String
  amount        Float
  category      String // INCOME, BUSINESS_EXPENSE, PERSONAL_EXPENSE, OWNER_DRAW

  weeklyEntry   WeeklyEntry @relation(fields: [weeklyEntryId], references: [id], onDelete: Cascade)
  weeklyEntryId String
}

model AccountBalance {
  id          String @id @default(uuid())
  accountName String
  balance     Float

  weeklyEntry   WeeklyEntry @relation(fields: [weeklyEntryId], references: [id], onDelete: Cascade)
  weeklyEntryId String
}

model InvestmentEntry {
  id     String @id @default(uuid())
  name   String
  amount Float

  weeklyEntry   WeeklyEntry @relation(fields: [weeklyEntryId], references: [id], onDelete: Cascade)
  weeklyEntryId String
}

model RecurringItem {
  id           String   @id @default(uuid())
  description  String
  amount       Float
  category     String   // INCOME, BUSINESS_EXPENSE, PERSONAL_EXPENSE, OWNER_DRAW, INVESTMENT
  frequency    String   @default("WEEKLY") // WEEKLY or MONTHLY
  scheduledDay Int      @default(-1) // WEEKLY: 0=Sun..6=Sat, MONTHLY: 1-31, -1=unset
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model TrackedInvestment {
  id               String   @id @default(uuid())
  symbol           String   // Ticker for stocks (AAPL), CoinGecko ID for crypto (bitcoin)
  name             String   // Display name
  type             String   // STOCK or CRYPTO
  shares           Float    @default(0)
  avgCost          Float    @default(0)
  recurringAmount  Float    @default(0) // Weekly auto-invest amount in USD
  recurringDay     Int      @default(-1) // Day of week: 0=Sun,1=Mon,...6=Sat, -1=disabled
  createdAt        DateTime @default(now())
}

model Reminder {
  id           String   @id @default(uuid())
  message      String
  frequency    String   @default("WEEKLY") // WEEKLY or MONTHLY
  scheduledDay Int      @default(-1) // WEEKLY: 0=Sun..6=Sat, MONTHLY: 1-31, -1=unset
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}
